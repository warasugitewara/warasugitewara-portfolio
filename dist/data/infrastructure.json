{
  "infrastructure": {
    "title": "自作鯖構成",
    "subtitle": "Proxmox VE によるゼロトラスト型ホームラボ",
    "overview": "Proxmox VE を基盤とした個人インフラ環境。ゼロトラストアクセスとシンプルな構成を重視。全サービスは Twingate を経由したセキュアなアクセスで、インターネットへの直接ポート公開は行わない。",

    "design_philosophy": [
      "ゼロトラスト型ネットワークアクセス — インターネットへのポート公開なし",
      "シンプルで保守性の高い構成",
      "Ed25519 SSH鍵認証 + パスワード認証無効化",
      "複数メディアへのバックアップ (USB + クラウド)",
      "ホームラボとして拡張可能なアーキテクチャ"
    ],

    "hypervisor": {
      "platform": "Proxmox VE 9.x",
      "purpose": "KVM/QEMU virtualization with LXC containers",
      "key_features": [
        "Web-based virtualization management",
        "VM / LXC コンテナ統合管理",
        "スナップショットとバックアップ",
        "TOTP 二要素認証"
      ]
    },

    "nodes": [
      {
        "id": "node1",
        "name": "Dell-1",
        "hardware": "Intel Core i3-6100 (4 threads) + RAM 16GB + SSD 128GB ＋ HDD 512GB",
        "role": "メインコンピュートノード",
        "purpose": "開発・サービス・ホームラボ実験環境の中心",

        "workloads": [
          {
            "type": "VM",
            "name": "dev-01",
            "os": "Debian 13",
            "purpose": "SSHベースの開発環境",
            "details": [
              "WezTerm + SSH による開発",
              "Neovim / CLI中心ワークフロー",
              "GitHub連携"
            ]
          },
          {
            "type": "VM",
            "name": "Music Bot",
            "os": "Ubuntu 24.04",
            "purpose": "Discord 音楽ボット",
            "details": "systemd サービスとして常時稼働"
          },
          {
            "type": "LXC",
            "name": "Twingate Connector",
            "purpose": "ゼロトラストリモートアクセスのためのトンネルエンドポイント"
          },
          {
            "type": "LXC",
            "name": "Obsidian_container",
            "purpose": "ObsidianのLivesync用DB"
          }
        ]
      }
    ],

    "network_design": {
      "topology": "ホームLAN (192.168.x.x) + Twingate overlay network",
      "security": [
        "インターネットへのポート公開なし",
        "全リモートアクセスは Twingate 経由",
        "SSHは内部ネットワークのみ",
        "外部とのゼロトラスト通信VPN"
      ],
      "dns": "ローカルDNS + ISP DNS"
    },

    "security_model": {
      "ssh": {
        "root_login": "disabled",
        "password_auth": "disabled",
        "key_type": "Ed25519",
        "access_method": "Twingate tunnel only"
      },

      "backup_strategy": [
        "Google Drive クラウドバックアップ",
        "USBストレージ コールドバックアップ",
        "Proxmox VMバックアップ"
      ],

      "authentication": {
        "proxmox": "TOTP 2FA enabled",
        "linux_vms": "SSH key authentication only"
      }
    },

